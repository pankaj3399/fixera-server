MONGODB_URI=
PORT=
JWT_SECRET=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
BREVO_API_KEY=
SMTP_SERVER=
SMTP_PORT=
SMTP_LOGIN=
FROM_EMAIL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
FRONTEND_URL=http://localhost:3000
GOOGLE_MAPS_API_KEY=

# Firebase Admin SDK — required for FCM push notifications
# Base64-encode your service account JSON (portable across macOS/Linux):
#   base64 serviceAccount.json | tr -d '\n'
FCM_SERVICE_ACCOUNT_JSON=

# Firecrawl — required for backlink URL verification
# Get your key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Stripe Keys (TEST MODE)
STRIPE_SECRET_KEY=sk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_51xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Configuration
STRIPE_DEFAULT_CURRENCY=EUR
STRIPE_SUPPORTED_CURRENCIES=EUR,USD,GBP,CAD,AUD
STRIPE_PLATFORM_COMMISSION_PERCENT=0

# Peppol e-invoicing providers (Belgian B2B invoices)
# Only needed when Admin > Settings > E-invoicing provider is "billit" or "odoo".
# With provider "manual" the UBL XML is generated and stored in S3 without dispatch.
BILLIT_PEPPOL_ENDPOINT=
BILLIT_API_KEY=
ODOO_PEPPOL_ENDPOINT=
ODOO_API_KEY=
